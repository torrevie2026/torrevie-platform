# Torrevie SaaS Platform — Environment Variable Template
# Copy to .env.local for local development. Never commit a file with real values.
# Production and staging values are set directly in Vercel and Supabase project settings, never in the repository.

# --- Supabase (per environment) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never referenced in client components, never shipped to the browser or to Flutter.
SUPABASE_SERVICE_ROLE_KEY=
# Server-only SQL connection for tenant-scoped route handlers.
DATABASE_URL=
TORREVIE_DATABASE_POOL_SIZE=5
TORREVIE_DATABASE_SSL=true
TORREVIE_DATABASE_SSL_REJECT_UNAUTHORIZED=false

# --- App identity / domains ---
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_ADMIN_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_CUSTOMER_PORTAL_URL=http://localhost:3000

# --- AI providers (add adapters as selected; do not hardcode a single provider assumption) ---
TEX_RECEIPT_AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_RECEIPT_MODEL=gemini-3.5-flash
GEMINI_RECEIPT_MODELS=gemini-3.5-flash,gemini-2.5-flash,gemini-3.1-flash-lite
OPENAI_API_KEY=
OPENAI_RECEIPT_MODEL=gpt-5.6
AI_PROVIDER_PRIMARY_API_KEY=
AI_PROVIDER_PRIMARY_NAME=
AI_PROVIDER_FALLBACK_API_KEY=
AI_PROVIDER_FALLBACK_NAME=

# --- Email / SMS / WhatsApp ---
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=hello@torrevie.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Torrevie <hello@torrevie.com>
SMS_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=
VAPI_API_KEY=

# --- Integration / webhook signing ---
WEBHOOK_SIGNING_SECRET=
# Server-only, used by TEX Google Places search and trip leg route estimates.
# Compatible aliases: GOOGLE_MAPS_PLATFORM_KEY, NEXT_PUBLIC_GOOGLE_MAPS_API_KEY,
# NEXT_PUBLIC_GOOGLE_MAPS_PLATFORM_KEY, VITE_GOOGLE_MAPS_API_KEY,
# VITE_GOOGLE_MAPS_PLATFORM_KEY, GOOGLE_API_KEY, GOOGLE_AI_KEY.
GOOGLE_MAPS_API_KEY=

# --- Observability ---
ERROR_TRACKING_DSN=
LOG_AGGREGATOR_TOKEN=

# --- Vercel (used by CI, not by the app at runtime) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID_ADMIN=
VERCEL_PROJECT_ID_CUSTOMER=
