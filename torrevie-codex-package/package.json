{
  "name": "torrevie-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Torrevie SaaS Platform monorepo.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --check",
    "typecheck": "pnpm -r --if-present typecheck:local",
    "test": "pnpm test:auth && pnpm test:tenant-context && pnpm test:permissions && pnpm test:observability && pnpm test:notifications && pnpm test:ci-pipeline && pnpm test:admin-portal && pnpm test:tenant-lifecycle && pnpm test:provisioning && pnpm test:subscriptions && pnpm test:fsm-entitlements && pnpm test:fsm-adaptive-ux && pnpm test:fsm-voice-core && pnpm test:fsm-roi && pnpm test:fsm-hardening && pnpm test:localization && pnpm test:customer-portal-shell && pnpm test:customer-admin && pnpm test:crm && pnpm test:tex",
    "test:auth": "node scripts/auth-claim-smoke.mjs",
    "test:tenant-context": "tsx packages/tenant-context/src/index.test.ts && tsx scripts/tenant-context-smoke.ts",
    "test:permissions": "tsx packages/permissions/src/index.test.ts",
    "test:observability": "tsx packages/observability/src/index.test.ts",
    "test:notifications": "tsx packages/notifications/src/index.test.ts",
    "test:ci-pipeline": "node scripts/ci-pipeline-smoke.mjs",
    "test:admin-portal": "tsx apps/admin-portal/lib/access.test.ts",
    "test:tenant-lifecycle": "tsx scripts/tenant-lifecycle-smoke.ts",
    "test:provisioning": "tsx packages/provisioning/src/index.test.ts",
    "test:subscriptions": "tsx scripts/subscription-management-smoke.ts",
    "test:fsm-entitlements": "tsx scripts/fsm-entitlements-smoke.ts",
    "test:fsm-adaptive-ux": "tsx scripts/fsm-adaptive-ux-smoke.ts",
    "test:fsm-voice-core": "tsx scripts/fsm-voice-core-smoke.ts",
    "test:fsm-roi": "tsx scripts/fsm-roi-smoke.ts",
    "test:fsm-hardening": "tsx scripts/fsm-hardening-smoke.ts",
    "test:localization": "tsx packages/localization/src/index.test.ts",
    "test:customer-portal-shell": "tsx scripts/customer-portal-localization-smoke.ts",
    "test:customer-admin": "tsx apps/customer-portal/lib/customer-administration.test.ts",
    "test:crm": "tsx apps/customer-portal/lib/crm.test.ts && tsx scripts/crm-vertical-smoke.ts",
    "test:tex": "tsx apps/customer-portal/lib/tex-ai.test.ts && tsx apps/customer-portal/lib/tex.test.ts && tsx apps/customer-portal/lib/tex-api.test.ts && tsx apps/customer-portal/lib/tex-cron.test.ts && tsx apps/customer-portal/lib/tex-webhooks.test.ts",
    "test:tex:browser": "node scripts/tex-browser-smoke.mjs",
    "test:fsm-phase0": "node scripts/fsm-phase0-smoke.mjs",
    "test:isolation": "node scripts/run-sql-tests.mjs",
    "tex:migrate-data:dry-run": "node scripts/migrate-tex-data.mjs",
    "tex:migrate-data:apply": "node scripts/migrate-tex-data.mjs --apply",
    "verify:tex:staging": "node scripts/verify-tex-staging.mjs",
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @torrevie/customer-portal dev",
    "supabase:start": "supabase start",
    "supabase:status": "supabase status",
    "supabase:smoke": "node scripts/supabase-smoke.mjs",
    "supabase:migrate": "supabase migration up --local",
    "supabase:reset": "supabase db reset --local",
    "supabase:seed": "supabase db reset --local"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "24.0.15",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.31.0",
    "pg": "^8.22.0",
    "prettier": "3.6.2",
    "supabase": "2.109.1",
    "tsx": "4.23.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0"
  }
}
