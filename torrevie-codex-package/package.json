{
  "name": "torrevie-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Torrevie SaaS Platform monorepo.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests defined yet for WP-1\"",
    "test:isolation": "node scripts/run-sql-tests.mjs",
    "build": "echo \"No build targets defined yet for WP-1\"",
    "dev": "echo \"Application dev servers start in later work packages\"",
    "supabase:start": "supabase start",
    "supabase:status": "supabase status",
    "supabase:smoke": "node scripts/supabase-smoke.mjs",
    "supabase:migrate": "supabase migration up --local",
    "supabase:reset": "supabase db reset --local",
    "supabase:seed": "supabase db reset --local"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "eslint": "9.31.0",
    "prettier": "3.6.2",
    "supabase": "2.109.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0"
  }
}
