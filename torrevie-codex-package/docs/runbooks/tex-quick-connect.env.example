# TEX Quick Connect persistent connector environment template.
# Copy this file to the protected runtime host outside Git, for example:
#   /etc/torrevie/tex-quick-connect.env
#
# Never commit a filled copy.

# Preferred: direct database URL for the shared Torrevie Supabase Postgres database.
DATABASE_URL=
TORREVIE_DATABASE_SSL=true
TORREVIE_DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Alternative: Supabase REST fallback. Use only when DATABASE_URL is unavailable.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tenant filter. Leave blank to watch all queued Quick Connect tenants.
TEX_QUICK_CONNECT_TENANT_ID=

# Runtime identity and storage. The session directory must be persistent and protected.
TEX_QUICK_CONNECT_INSTANCE_ID=tex-qc-prod-01
TEX_QUICK_CONNECT_SESSION_DIR=/var/lib/torrevie/tex-quick-connect-sessions

# Polling, heartbeat, and logs.
TEX_QUICK_CONNECT_POLL_MS=5000
TEX_QUICK_CONNECT_MAX_SESSIONS=5
TEX_QUICK_CONNECT_HEARTBEAT_MS=30000
TEX_QUICK_CONNECT_HEALTH_WINDOW_SECONDS=120
TEX_QUICK_CONNECT_LOG_LEVEL=info
